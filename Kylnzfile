vmid: "qga-auto-mount-test"
vmname: "Auto Mount VM"
base_image: "/home/kenjiro/kylnz/.kylnz/base/base.qcow2"
memory: 512
output_dir: "./.kylnz/layers"

# 自動マウント設定
data_disk: "./.kylnz/data/persistence.qcow2"
data_mount: "/mnt/my_persistent_data" # 好きな場所を指定

steps:
  - type: "run"
    command: "apk update && apk add e2fsprogs" # mkfsのために必要
    
  - type: "run"
    command: "echo 'It works!' > /mnt/my_persistent_data/success.txt"

  - type: "run"
    command: "ls -l /mnt/my_persistent_data/success.txt"